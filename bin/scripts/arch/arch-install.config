# For arch-install
INSTALL_TARGET="/dev/sdb"       # full device path eg:/dev/sdX
PARTITIONING_SCHEME="UEFI-GPT"  # MBR / BIOS-GPT / UEFI-GPT
BOOT_PART_TYPE="ext2"           # valid mkfs fs
OTHERS_PART_TYPE="ext4"         # valid mkfs fs
VG_NAME="arch-vg"               # volume group name
LV_ROOT_SIZE="50G"              # root lvm part size format d*[M,G] eg 50G
LV_HOME_SIZE="150G"             # home lvm part size format d*[M,G] eg 150G
LV_SWAP_SIZE="2G"               # swap lvm part size format d*[M,G] eg 150G

# For inside-chroot
HOST_NAME="Krach"               # hostname
ROOT_PASSWORD="password"        # root user password
USER_NAME="s33d"                # normal user name
USER_PASSWORD="password"        # normal user password

source packages.config